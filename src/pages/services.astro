---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services">
  <section class="py-16 bg-[#0a0a0a]">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-display text-center text-white mb-12">Services Overview</h1>
      
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Left Column -->
        <div class="space-y-8">
          <!-- Shock Rebuild Pricing -->
          <div>
            <h2 class="text-xl font-display text-red-500 mb-4">Shock Rebuild Pricing</h2>
            <ul class="space-y-2 text-gray-300">
              <li class="flex justify-between">
                <span>• 2.0 Bump Stop</span>
                <span class="text-white">$170/pair</span>
              </li>
              <li class="flex justify-between">
                <span>• 2.5 Bump Stop</span>
                <span class="text-white">$190/pair</span>
              </li>
              <li class="flex justify-between">
                <span>• 2.0/2.5 Coilover or Smooth Body</span>
                <span class="text-white">$270/pair</span>
              </li>
              <li class="flex justify-between">
                <span>• 2.5 Bypass</span>
                <span class="text-white">$300/pair</span>
              </li>
              <li class="flex justify-between">
                <span>• 3.0 Coilover or Smooth Body</span>
                <span class="text-white">$290/pair</span>
              </li>
              <li class="flex justify-between">
                <span>• 3.0 Bypass</span>
                <span class="text-white">$320/pair</span>
              </li>
              <li class="flex justify-between">
                <span>• 3.5 Bypass</span>
                <span class="text-white">$355/pair</span>
              </li>
              <li class="flex justify-between">
                <span>• 4.0 Bypass</span>
                <span class="text-white">$420/pair</span>
              </li>
              <li class="flex justify-between">
                <span>• 4.5 Bypass</span>
                <span class="text-white">$455/pair</span>
              </li>
            </ul>
          </div>

          <!-- Standard Services -->
          <div>
            <h2 class="text-xl font-display text-red-500 mb-4">Standard Services</h2>
            <p class="text-gray-300 mb-2">
              Rebuild includes new oil, nitrogen fill, and replacement of seals (excluding top cap).
            </p>
            <p class="text-gray-300 mb-2">
              Coil removal/reinstallation — <span class="text-white">$30/pair</span>
            </p>
            <p class="text-gray-400 text-sm italic">
              Extra charge applies for rush jobs.
            </p>
          </div>

          <!-- Add-On Labor & Machining -->
          <div>
            <h2 class="text-xl font-display text-red-500 mb-4">Add-On Labor & Machining</h2>
            <p class="text-gray-300 mb-3">Extra services such as:</p>
            <ul class="space-y-1 text-gray-300 ml-4">
              <li>• Rod end changes</li>
              <li>• Excessive cleaning</li>
              <li>• Cerakote teardown/reassembly</li>
              <li>• Machining work</li>
            </ul>
            <p class="text-white mt-3 font-semibold">All billed at $100/hour.</p>
          </div>
        </div>

        <!-- Right Column -->
        <div class="space-y-8">
          <!-- Coating & Appearance Options -->
          <div>
            <h2 class="text-xl font-display text-red-500 mb-4">Coating & Appearance Options</h2>
            <p class="text-gray-300 mb-2">
              Shock coating available by request at additional cost.
            </p>
            <p class="text-gray-300">
              Cerakote & anodizing require a deposit.
            </p>
          </div>

          <!-- Brand Support -->
          <div>
            <h2 class="text-xl font-display text-red-500 mb-4">Brand Support</h2>
            <p class="text-gray-300 mb-3">Brands serviced include:</p>
            <ul class="space-y-1 text-gray-300 ml-4">
              <li>• King</li>
              <li>• Fox</li>
              <li>• Sway-Away</li>
              <li>• Icon</li>
              <li>• Radflo</li>
              <li>• Walker Evans</li>
            </ul>
            <p class="text-gray-400 text-sm mt-3 italic">
              For other brands, please send an inquiry.
            </p>
          </div>

          <!-- Timing & Turnaround -->
          <div>
            <h2 class="text-xl font-display text-red-500 mb-4">Timing & Turnaround</h2>
            <p class="text-gray-300 mb-2">
              Available for suspension tuning on weekends with notice. Deposit required to confirm date.
            </p>
            <p class="text-gray-300 mb-2">
              Turnaround time 3-10 days for service/valving. Cerakote jobs: 6-8 weeks.
            </p>
            <p class="text-gray-400 text-sm italic">
              *Same-day service not offered due to internal condition unpredictability.
            </p>
          </div>

          <!-- Starting Price for Revalve -->
          <div>
            <h2 class="text-xl font-display text-red-500 mb-4">Starting Price for Revalve</h2>
            <p class="text-gray-300">
              <span class="text-white font-semibold">$200/pair</span> — contact us for a quote tailored to your setup.
            </p>
          </div>
        </div>
      </div>

      <!-- CTA Button -->
      <div class="mt-12 text-center">
        <a href="/inquiry" class="btn-primary inline-block">
          Reach Out to Book or Ask Questions
        </a>
      </div>
    </div>
  </section>
</Layout>
