---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inquiry">
  <section class="py-16 bg-[#0a0a0a]">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-display text-center text-white mb-8">Inquiry Form</h1>
      
      <form 
        action="https://formspree.io/f/YOUR_FORM_ID" 
        method="POST" 
        class="space-y-6"
        id="inquiry-form"
      >
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Full Name -->
          <div>
            <label for="name" class="block text-gray-300 mb-2">Full Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required
              placeholder="Your name"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-gray-300 mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required
              placeholder="your@email.com"
            />
          </div>

          <!-- Phone Number -->
          <div>
            <label for="phone" class="block text-gray-300 mb-2">Phone Number</label>
            <input 
              type="tel" 
              id="phone" 
              name="phone" 
              placeholder="(555) 555-5555"
            />
          </div>

          <!-- Vehicle Info -->
          <div>
            <label for="vehicle" class="block text-gray-300 mb-2">Vehicle Info</label>
            <input 
              type="text" 
              id="vehicle" 
              name="vehicle" 
              placeholder="Year, Make, Model"
            />
          </div>
        </div>

        <!-- Text OK Checkbox -->
        <div class="flex items-center gap-2">
          <input 
            type="checkbox" 
            id="text-ok" 
            name="text_ok" 
            class="w-4 h-4 rounded bg-[#1a1a1a] border-gray-600 text-red-500 focus:ring-red-500"
          />
          <label for="text-ok" class="text-gray-300">Text OK</label>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <!-- Type of Service -->
          <div>
            <label for="service" class="block text-gray-300 mb-2">Type of Service</label>
            <select id="service" name="service" required>
              <option value="">Select a service</option>
              <option value="rebuild">Shock Rebuild</option>
              <option value="revalve">Revalve</option>
              <option value="tuning">Suspension Tuning</option>
              <option value="cerakote">Cerakote</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Preferred Date & Time -->
          <div>
            <label for="preferred-date" class="block text-gray-300 mb-2">Preferred Date & Time</label>
            <input 
              type="datetime-local" 
              id="preferred-date" 
              name="preferred_date"
            />
          </div>
        </div>

        <!-- Additional Notes -->
        <div>
          <label for="notes" class="block text-gray-300 mb-2">Additional Notes</label>
          <textarea 
            id="notes" 
            name="notes" 
            rows="5"
            placeholder="Tell us more about your project, current setup, or any questions..."
          ></textarea>
        </div>

        <!-- File Upload Note -->
        <div>
          <p class="text-gray-400 text-sm">
            <span class="text-gray-300">Upload Photo (optional):</span> For photos of your shocks, please email them directly or text them after submitting this form.
          </p>
        </div>

        <!-- Submit Button -->
        <div class="pt-4">
          <button type="submit" class="btn-primary w-full md:w-auto">
            Submit Inquiry
          </button>
        </div>
      </form>

      <!-- Response Time Note -->
      <p class="text-gray-500 text-sm text-center mt-8">
        Please allow up to 24 hours for a response. We'll get you squared away.
      </p>
    </div>
  </section>
</Layout>

<script>
  // Form submission handling (placeholder - replace with actual form backend)
  const form = document.getElementById('inquiry-form');
  form?.addEventListener('submit', (e) => {
    // Form will submit to Formspree or similar service
    // Update the action URL with your actual form endpoint
  });
</script>
