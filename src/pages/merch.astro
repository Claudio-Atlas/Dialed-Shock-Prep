---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Merch">
  <section class="py-16 bg-[#0a0a0a]">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-display text-center text-white mb-4">Merch Shop</h1>
      <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto">
        Rep the Dialed lifestyle. Gear up with our official merch — hats, hoodies, stickers, and more.
      </p>

      <!-- Coming Soon / Placeholder -->
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Merch Item 1 -->
        <div class="bg-[#1a1a1a] rounded-lg overflow-hidden border border-gray-800 card-hover">
          <div class="aspect-square bg-[#252525] flex items-center justify-center">
            <img 
              src="/images/logo.jpg" 
              alt="Dialed Shock Prep Logo Tee" 
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-4">
            <h3 class="text-white font-semibold">Pin-Up Logo Tee</h3>
            <p class="text-gray-400 text-sm mt-1">Classic black tee with signature logo</p>
            <p class="text-red-500 font-semibold mt-2">Coming Soon</p>
          </div>
        </div>

        <!-- Merch Item 2 -->
        <div class="bg-[#1a1a1a] rounded-lg overflow-hidden border border-gray-800 card-hover">
          <div class="aspect-square bg-[#252525] flex items-center justify-center">
            <span class="text-6xl">🧢</span>
          </div>
          <div class="p-4">
            <h3 class="text-white font-semibold">Dialed Snapback</h3>
            <p class="text-gray-400 text-sm mt-1">Black cap with embroidered logo</p>
            <p class="text-red-500 font-semibold mt-2">Coming Soon</p>
          </div>
        </div>

        <!-- Merch Item 3 -->
        <div class="bg-[#1a1a1a] rounded-lg overflow-hidden border border-gray-800 card-hover">
          <div class="aspect-square bg-[#252525] flex items-center justify-center">
            <span class="text-6xl">🎯</span>
          </div>
          <div class="p-4">
            <h3 class="text-white font-semibold">Sticker Pack</h3>
            <p class="text-gray-400 text-sm mt-1">Die-cut vinyl stickers for your rig</p>
            <p class="text-red-500 font-semibold mt-2">Coming Soon</p>
          </div>
        </div>

        <!-- Merch Item 4 -->
        <div class="bg-[#1a1a1a] rounded-lg overflow-hidden border border-gray-800 card-hover">
          <div class="aspect-square bg-[#252525] flex items-center justify-center">
            <span class="text-6xl">🧥</span>
          </div>
          <div class="p-4">
            <h3 class="text-white font-semibold">Dialed Hoodie</h3>
            <p class="text-gray-400 text-sm mt-1">Heavyweight hoodie, front & back print</p>
            <p class="text-red-500 font-semibold mt-2">Coming Soon</p>
          </div>
        </div>

        <!-- Merch Item 5 -->
        <div class="bg-[#1a1a1a] rounded-lg overflow-hidden border border-gray-800 card-hover">
          <div class="aspect-square bg-[#252525] flex items-center justify-center">
            <span class="text-6xl">🏷️</span>
          </div>
          <div class="p-4">
            <h3 class="text-white font-semibold">Shop Banner</h3>
            <p class="text-gray-400 text-sm mt-1">Large vinyl banner for your garage</p>
            <p class="text-red-500 font-semibold mt-2">Coming Soon</p>
          </div>
        </div>

        <!-- Merch Item 6 -->
        <div class="bg-[#1a1a1a] rounded-lg overflow-hidden border border-gray-800 card-hover">
          <div class="aspect-square bg-[#252525] flex items-center justify-center">
            <span class="text-6xl">🔑</span>
          </div>
          <div class="p-4">
            <h3 class="text-white font-semibold">Keychain</h3>
            <p class="text-gray-400 text-sm mt-1">Metal keychain with logo</p>
            <p class="text-red-500 font-semibold mt-2">Coming Soon</p>
          </div>
        </div>
      </div>

      <!-- Notify CTA -->
      <div class="mt-12 text-center">
        <p class="text-gray-400 mb-4">Want to know when merch drops?</p>
        <a href="/inquiry" class="btn-primary inline-block">
          Send Us a Message
        </a>
      </div>
    </div>
  </section>
</Layout>
