---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative py-20 md:py-32 gradient-dark">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-6xl font-display text-white mb-4">
        Precision Shocks. <span class="text-red-500">Dialed</span> Performance.
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-8">
        Expert shock services and performance tuning for lifted and off-road trucks. Built to handle more.
      </p>
      <a href="/inquiry" class="btn-primary inline-block">
        Book a Service
      </a>
    </div>
  </section>

  <!-- Why / What We Offer Section -->
  <section class="py-16 bg-[#0f0f0f]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Why Dialed Shock Prep Works -->
        <div>
          <h2 class="text-2xl font-display text-white mb-6">Why Dialed Shock Prep Works</h2>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-red-500 mt-1">■</span>
              <span class="text-gray-300">Precision shock tuning for lifted/off-road trucks</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 mt-1">■</span>
              <span class="text-gray-300">Built by a racer — trusted by the community</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 mt-1">■</span>
              <span class="text-gray-300">Fast turnaround times and responsive service</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 mt-1">■</span>
              <span class="text-gray-300">Clear communication and no BS</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-500 mt-1">■</span>
              <span class="text-gray-300">One-stop shop: shocks, setup, and style</span>
            </li>
          </ul>
        </div>

        <!-- What We Offer -->
        <div>
          <h2 class="text-2xl font-display text-red-500 mb-6">What We Offer</h2>
          <div class="space-y-4">
            <div class="bg-[#1a1a1a] p-4 rounded-lg border border-gray-800 card-hover">
              <h3 class="text-white font-semibold flex items-center gap-2">
                <span>🔧</span> Shock Services
              </h3>
              <p class="text-gray-400 text-sm mt-1">Rebuilds, tuning, and full setup for all your suspension needs.</p>
            </div>
            <div class="bg-[#1a1a1a] p-4 rounded-lg border border-gray-800 card-hover">
              <h3 class="text-white font-semibold flex items-center gap-2">
                <span>⚙️</span> Performance Tuning
              </h3>
              <p class="text-gray-400 text-sm mt-1">Dialed setups for aggressive terrain, racing, or daily ride comfort.</p>
            </div>
            <div class="bg-[#1a1a1a] p-4 rounded-lg border border-gray-800 card-hover">
              <h3 class="text-white font-semibold flex items-center gap-2">
                <span>👕</span> Merch Shop
              </h3>
              <p class="text-gray-400 text-sm mt-1">Grab gear that reps the lifestyle — hats, hoodies, stickers and more.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Specialized Services Cards -->
  <section class="py-16 bg-[#0a0a0a]">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-display text-center text-white mb-12">Our Specialized Services</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Suspension Tuning -->
        <div class="bg-[#1a1a1a] p-6 rounded-lg border border-gray-800 card-hover">
          <div class="w-12 h-12 bg-[#252525] rounded-lg flex items-center justify-center mb-4">
            <span class="text-2xl">📋</span>
          </div>
          <h3 class="text-lg font-semibold text-red-500 mb-2">Suspension Tuning</h3>
          <p class="text-gray-400 text-sm">Weekend availability with advance notice. Deposit required after evaluating shocks.</p>
        </div>

        <!-- Drop-off Scheduling -->
        <div class="bg-[#1a1a1a] p-6 rounded-lg border border-gray-800 card-hover">
          <div class="w-12 h-12 bg-[#252525] rounded-lg flex items-center justify-center mb-4">
            <span class="text-2xl">📅</span>
          </div>
          <h3 class="text-lg font-semibold text-red-500 mb-2">Drop-off Scheduling</h3>
          <p class="text-gray-400 text-sm">Email preferred date/time. Send year & photos of shocks to confirm availability.</p>
        </div>

        <!-- Rush Jobs -->
        <div class="bg-[#1a1a1a] p-6 rounded-lg border border-gray-800 card-hover">
          <div class="w-12 h-12 bg-[#252525] rounded-lg flex items-center justify-center mb-4">
            <span class="text-2xl">⚡</span>
          </div>
          <h3 class="text-lg font-semibold text-red-500 mb-2">Rush Jobs Available</h3>
          <p class="text-gray-400 text-sm">Expedited service available for an additional fee. Turnaround usually 2-10 days.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-pattern py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-display text-white mb-4">
        Ready to Dial In Your Suspension?
      </h2>
      <p class="text-white/90 mb-8 max-w-2xl mx-auto">
        Whether it's a basic rebuild or a full Cerakote custom job, we've got you covered. Send an inquiry today — we'll walk you through the process and get your shocks back to top form.
      </p>
      <a href="/inquiry" class="inline-block bg-white text-red-600 px-8 py-3 rounded font-semibold hover:bg-gray-100 transition-colors">
        Send an Inquiry
      </a>
      <p class="text-white/70 text-sm mt-4">
        Please allow up to 24 hours for a response. We'll get you squared away.
      </p>
    </div>
  </section>
</Layout>
