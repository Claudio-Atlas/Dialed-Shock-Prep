---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Expert shock services and performance tuning for lifted and off-road trucks. Built to handle more." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Dialed Shock Prep</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-[#0a0a0a]/95 backdrop-blur-sm border-b border-gray-800">
      <nav class="max-w-6xl mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="text-2xl font-display text-red-500 hover:text-red-400 transition-colors">
            Dialed Shock Prep
          </a>
          <div class="hidden md:flex items-center gap-8">
            <a href="/" class="text-gray-300 hover:text-white transition-colors">Home</a>
            <a href="/services" class="text-gray-300 hover:text-white transition-colors">Services</a>
            <a href="/merch" class="text-gray-300 hover:text-white transition-colors">Merch</a>
            <a href="/inquiry" class="text-gray-300 hover:text-white transition-colors">Inquiry</a>
          </div>
          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden text-gray-300 hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-gray-800 pt-4">
          <div class="flex flex-col gap-4">
            <a href="/" class="text-gray-300 hover:text-white transition-colors">Home</a>
            <a href="/services" class="text-gray-300 hover:text-white transition-colors">Services</a>
            <a href="/merch" class="text-gray-300 hover:text-white transition-colors">Merch</a>
            <a href="/inquiry" class="text-gray-300 hover:text-white transition-colors">Inquiry</a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#0a0a0a] border-t border-gray-800 py-8">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-400">Fullerton, CA</span>
          </div>
          <p class="text-gray-500 text-sm">
            Serious Suspension for Serious Off-Road Builds
          </p>
          <div class="flex gap-6 text-sm text-gray-400">
            <a href="/services" class="hover:text-white transition-colors">Services</a>
            <a href="/inquiry" class="hover:text-white transition-colors">Send Inquiry</a>
            <a href="/inquiry" class="hover:text-white transition-colors">Contact</a>
          </div>
        </div>
        <div class="mt-6 pt-6 border-t border-gray-800 text-center text-gray-500 text-sm">
          &copy; {new Date().getFullYear()} Dialed Shock Prep. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
